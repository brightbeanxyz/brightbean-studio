{
  "name": "BrightBean Studio",
  "version": "1.0.0",
  "modules": [
    "studio-domain",
    "studio-infrastructure",
    "studio-application",
    "studio-web"
  ],
  "includePatterns": [
    "**/*.kt"
  ],
  "excludePatterns": [
    "**/build/**",
    "**/target/**",
    "**/.gradle/**",
    "**/.mvn/**"
  ],
  "lint": {
    "rules": [
      "ArchitectureReactor",
      "AvoidAnnotation",
      "AvoidConstructorParameter",
      "AvoidLambda",
      "AvoidMultipleStatements",
      "AvoidNestedFunctions",
      "AvoidNullExpression",
      "AvoidOperatorFunctionName",
      "AvoidPrint",
      "AvoidProtectedPropertyInDataClass",
      "AvoidReturnInAnonymousFunction",
      "AvoidUnitExpression",
      "AvoidVarProperty",
      "BeConsistentWithPrimaryConstructorParameterNaming",
      "ClassHeader",
      "DataClassMustHavePrimaryConstructor",
      "DoNotUseObjectDeployment",
      "DoNotUsePrivateModifier",
      "Don'tPlaceTaskCodeInConstructor",
      "EnumValues",
      "FilenameMatchesClassifier",
      "FilenameMatchesFolder",
      "ForbiddenAnnotation",
      "ForbiddenClass",
      "ForbiddenFunction",
      "ForbiddenImport",
      "ForbiddenProperty",
      "HideUtilityClassConstructor",
      "IllegalModifierOrder",
      "IncludeDirection",
      "InterfaceNames",
      "KeepFirstLastAnimation",
      "MatchingFilename",
      "NoCompanionAnnotation",
      "NoDataClass",
      "NoElseExpression",
      "NoInheritedPropertyInDataClass",
      "NoKotlinVersionInManifest",
      "NoObjectLiteral",
      "NoParameterAlias",
      "NoPrivateModifier",
      "NoProxyInterface",
      "NoRelativeImports",
      "NoReplaceableByMethodCall",
      "NoSetterProperty",
      "NoSuperiorMemberAsDelegate",
      "NoUnitReturnExpression",
      "NoVarProperty",
      "NonNullableVariableAgainstNonNullableType",
      "NotCanonicalDeclaration",
      "ObjectClass",
      "OneBlockPerFolder",
      "OnlyFunctions",
      "OptionalChaining",
      "PackagePath",
      "PreferCompanionObject",
      "PreferDataClass",
      "PreferInterface",
      "PreferSealedClass",
      "PreferToUsePackageDirective",
      "PrimaryConstructorRequired",
      "PrintLineLength",
      "PropertyClass",
      "PropertyConstant",
      "PropertyInDataClass",
      "RedundantCallbackReceiver",
      "RedundantConstructor",
      "RedundantExplicitType",
      "RedundantInternalModifier",
      "RedundantNamePrefixInPrimaryConstructor",
      "RedundantObjectTypeDeclaration",
      "RedundantParameterInPrimaryConstructor",
      "RedundantVisibilityModifier",
      "ReturnType",
      "SecondArchitectureComponent",
      "SealedClassSuperClass",
      "ShouldHavePrimaryConstructor",
      "ShouldNotUseConstructorPropertySharing",
      "ThrowException",
      "UnnecessaryAbstractClassMembers",
      "UnnecessaryCompanion",
      "UnnecessaryConstructor",
      "UnnecessaryInheritDoc",
      "UnnecessaryInnerClass",
      "UnnecessaryInnerClassConstructor",
      "UnnecessaryKotlinImport",
      "UnnecessaryLastCommaInMultilineClass",
      "UnnecessaryLocalTemporaryVariable",
      "UnnecessaryNamePrefixInPrimaryConstructor",
      "UnnecessaryObjectTypeDeclaration",
      "UnnecessaryPackageDirective",
      "UnnecessaryParameterInPrimaryConstructor",
      "UnnecessaryPrivateFunction",
      "UnnecessaryPropertyNamePrefix",
      "UnnecessaryPublicClass",
      "UnnecessaryReceiverAlias",
      "UnnecessaryReturnStatement",
      "UnnecessarySetter",
      "UnnecessaryVisibilityModifier",
      "UseAbstract",
      "UseAnyOrNoneInsteadOfFind",
      "UseBlockStatement",
      "UseBracesInConditionalExpressions",
      "UseBundle",
      "UseCoroutine",
      "UseDataClass",
      "UseExpressionBody",
      "UseExtensionFunctions",
      "UseFirstItemOrFirstOrNull",
      "UseFunctionName",
      "UseFunctionNaming",
      "UseHasCondition",
      "UseIfExpression",
      "UseIn",
      "UseIsEmpty",
      "UseLabeledExpression",
      "UseLateInit",
      "UseMeaningfulName",
      "UseNotNull",
      "UseObject",
      "UseOrEmpty",
      "UsePrimaryConstructor",
      "UseSealedEnum",
      "UseScope",
      "UseSealedClass",
      "UseSecondaryConstructor",
      "UseTrailingComma",
      "UseTransient",
      "UseWhen",
      "VisibilityModifier",
      "WrongAnnotationPackage"
    ]
  }
}
